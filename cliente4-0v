<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#FF2D78">
<title>BLIM — Cliente</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

:root {
  --pk: #FF2D78;
  --pk2: #FF6B9D;
  --pks: #FFF0F5;
  --dk: #1C1C1E;
  --g5: #8E8E93;
  --g9: #E5E5EA;
  --g10: #F2F2F7;
  --ok: #34C759;
  --er: #FF3B30;
  --rf: 999px;
  --r: 14px;
  --rl: 20px;
  --f: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
}

html, body {
  height: 100%;
  overflow: hidden;
  background: #000;
}

body {
  font-family: var(--f);
  background: #fff;
}

#app {
  max-width: 430px;
  margin: 0 auto;
  height: 100vh;
  background: #fff;
  position: relative;
  overflow: hidden;
}

/* Telas */
.scr {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: #fff;
  transform: translateX(100%);
  transition: transform 0.38s cubic-bezier(0.32, 0.72, 0, 1);
  z-index: 1;
  overflow: hidden;
}

.scr.on {
  transform: translateX(0);
  z-index: 10;
}

.sc {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
}

.sb {
  height: 34px;
}

/* Botões */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 17px 24px;
  border: none;
  border-radius: var(--rf);
  font-family: var(--f);
  font-size: 17px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.15s;
}

.btn:active {
  transform: scale(0.97);
}

.bpk {
  background: linear-gradient(135deg, var(--pk), var(--pk2));
  color: #fff;
  box-shadow: 0 6px 24px rgba(255, 45, 120, 0.38);
}

.bgh {
  background: var(--g10);
  color: var(--dk);
}

.ber {
  background: linear-gradient(135deg, var(--er), #FF6B6B);
  color: #fff;
}

/* Inputs */
.inp {
  width: 100%;
  padding: 15px 16px;
  background: var(--g10);
  border: 1.5px solid transparent;
  border-radius: 10px;
  font-family: var(--f);
  font-size: 16px;
  color: var(--dk);
  outline: none;
}

.inp:focus {
  background: #fff;
  border-color: var(--pk);
}

.iw {
  margin-bottom: 14px;
}

.iw label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: var(--g5);
  margin-bottom: 6px;
}

/* Header */
.tb {
  padding: 14px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fff;
  border-bottom: 0.5px solid var(--g9);
}

.tt {
  flex: 1;
  font-size: 17px;
  font-weight: 700;
  text-align: center;
}

.bk {
  width: 38px;
  height: 38px;
  border-radius: var(--rf);
  background: var(--g10);
  border: none;
  cursor: pointer;
  font-size: 22px;
  color: var(--pk);
}

/* Hero */
.hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 32px;
  text-align: center;
}

.lm {
  width: 88px;
  height: 88px;
  background: linear-gradient(135deg, var(--pk), #FF8FB3);
  border-radius: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  margin-bottom: 22px;
  animation: fl 3s infinite;
}

@keyframes fl {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.lt {
  font-size: 52px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--pk), #FF8FB3);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16px;
}

/* Toast */
.toast {
  position: fixed;
  bottom: 90px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(28, 28, 30, 0.92);
  backdrop-filter: blur(10px);
  color: #fff;
  padding: 12px 22px;
  border-radius: var(--rf);
  font-size: 14px;
  font-weight: 600;
  z-index: 9999;
  opacity: 0;
  transition: all 0.32s;
  pointer-events: none;
  white-space: nowrap;
}

.toast.on {
  opacity: 1;
}

/* Splash */
#splash {
  position: fixed;
  inset: 0;
  background: linear-gradient(135deg, #0A0A0F 0%, #1A0A1A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100000;
  flex-direction: column;
  transition: opacity 0.5s;
}

#splash.hidden {
  opacity: 0;
  pointer-events: none;
}

.splash-icon {
  width: 88px;
  height: 88px;
  background: linear-gradient(135deg, var(--pk), #FF8FB3);
  border-radius: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  margin-bottom: 22px;
  animation: fl 3s infinite;
}

.splash-logo {
  font-size: 72px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--pk), var(--pk2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16px;
  animation: splashPulse 2s infinite;
}

.splash-sub {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.4);
}

@keyframes splashPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* Grid e Categorias */
.cgrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  padding: 14px;
}

.cc {
  background: #fff;
  border-radius: 14px;
  padding: 14px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7px;
  cursor: pointer;
  border: 1px solid var(--g9);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
}

.cc:active {
  transform: scale(0.96);
}

/* Bottom Nav */
.nb {
  height: 60px;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  border-top: 0.5px solid var(--g9);
  display: flex;
}

.ni {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  cursor: pointer;
}

.ni .ic {
  font-size: 23px;
}

.ni .lb {
  font-size: 10px;
  font-weight: 600;
  color: var(--g5);
}

.ni.on .lb {
  color: var(--pk);
}

/* Mapa */
#map1, #map2 {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.leaflet-control-zoom {
  border: none !important;
  border-radius: 14px !important;
  overflow: hidden;
}

/* Forma de pagamento */
.pr {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 16px;
  border-radius: 14px;
  margin-bottom: 9px;
  cursor: pointer;
  background: var(--g10);
  border: 2px solid transparent;
}

.pr.on {
  background: var(--pks);
  border-color: var(--pk);
}

.pck {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid var(--g7);
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.pr.on .pck {
  background: var(--pk);
  border-color: var(--pk);
  color: #fff;
  content: "✓";
}

/* Status */
.tld {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
}

.tld.dk {
  background: var(--pk);
  color: #fff;
}

.tld.wt {
  background: var(--g9);
  color: var(--g5);
}

.tll {
  width: 2px;
  background: var(--g9);
  margin: 2px 13px;
}

.tli {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
}

/* Loading */
.sp {
  width: 20px;
  height: 20px;
  border: 2.5px solid var(--pk2);
  border-top-color: var(--pk);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  display: inline-block;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
</style>
</head>
<body>

<div id="splash">
  <div class="splash-icon">💝</div>
  <div class="splash-logo">BLIM</div>
  <div class="splash-sub">serviços sob medida</div>
</div>

<div id="app">
<div class="toast" id="toast"></div>

<!-- Tela inicial -->
<div class="scr on" id="s-splash">
  <div class="hero">
    <div class="lm">💝</div>
    <div class="lt">blim</div>
    <p style="margin-bottom: 40px; color: var(--g5);">Serviços sob medida para você 💕</p>
    <button class="btn bpk" onclick="nav('s-register')" style="margin-bottom: 10px;">Criar minha conta</button>
    <button class="tlb" style="background: none; border: none; color: var(--pk); font-weight: 600; padding: 12px;" onclick="nav('s-login')">Já tenho conta → Entrar</button>
  </div>
</div>

<!-- Cadastro -->
<div class="scr" id="s-register">
  <div class="tb"><button class="bk" onclick="nav('s-splash')">‹</button><div class="tt">Criar conta</div><div class="ph"></div></div>
  <div class="sc">
    <div class="iw"><label>Nome completo</label><input class="inp" id="rn" type="text" placeholder="Seu nome"></div>
    <div class="iw"><label>CPF</label><input class="inp" id="rcpf" type="tel" placeholder="000.000.000-00"></div>
    <div class="iw"><label>E-mail</label><input class="inp" id="re" type="email" placeholder="seu@email.com"></div>
    <div class="iw"><label>Celular</label><input class="inp" id="rphone" type="tel" placeholder="(00) 90000-0000"></div>
    <div class="iw"><label>Senha</label><input class="inp" id="rpw" type="password" placeholder="Mínimo 8 caracteres"></div>
    <div class="cr" style="display: flex; gap: 10px; margin-bottom: 20px;"><input type="checkbox" id="rt"><span>Aceito os <strong>termos</strong></span></div>
    <button class="btn bpk" onclick="doRegister()">Criar conta</button>
  </div>
</div>

<!-- Login -->
<div class="scr" id="s-login">
  <div class="tb"><button class="bk" onclick="nav('s-splash')">‹</button><div class="tt">Entrar</div><div class="ph"></div></div>
  <div class="sc">
    <div class="iw"><label>E-mail</label><input class="inp" id="le" type="email" placeholder="seu@email.com"></div>
    <div class="iw"><label>Senha</label><input class="inp" id="lp" type="password" placeholder="••••••••"></div>
    <div id="div-2fa" style="display: none;" class="iw"><label>Código 2FA</label><input class="inp" id="code2fa" type="text" placeholder="000000"></div>
    <button class="tlb" style="background: none; border: none; color: var(--pk); padding: 12px; width: 100%; text-align: right;" onclick="nav('s-forgot')">Esqueci minha senha</button>
    <button class="btn bpk" onclick="doLogin()">Entrar</button>
    <div style="margin: 20px 0; text-align: center;">ou</div>
    <button class="btn bgh" onclick="nav('s-register')">Criar conta grátis</button>
  </div>
</div>

<!-- Esqueci senha -->
<div class="scr" id="s-forgot">
  <div class="tb"><button class="bk" onclick="nav('s-login')">‹</button><div class="tt">Recuperar senha</div><div class="ph"></div></div>
  <div class="sc">
    <p style="margin-bottom: 20px;">Digite seu e-mail</p>
    <div class="iw"><input class="inp" id="reset-email" type="email" placeholder="seu@email.com"></div>
    <button class="btn bpk" onclick="forgotPassword()">Enviar link</button>
    <button class="btn bgh" onclick="nav('s-login')" style="margin-top: 10px;">Voltar</button>
  </div>
</div>

<!-- Redefinir senha -->
<div class="scr" id="s-reset-password">
  <div class="tb"><button class="bk" onclick="nav('s-login')">‹</button><div class="tt">Nova senha</div><div class="ph"></div></div>
  <div class="sc">
    <div class="iw"><input class="inp" id="new-password" type="password" placeholder="Nova senha"></div>
    <div class="iw"><input class="inp" id="confirm-password" type="password" placeholder="Confirmar senha"></div>
    <button class="btn bpk" onclick="submitResetPassword()">Redefinir</button>
  </div>
</div>

<!-- Home -->
<div class="scr" id="s-home">
  <div style="padding: 20px; background: #fff;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <div><div style="font-size: 14px; color: var(--g5);">Olá,</div><div style="font-size: 22px; font-weight: 800;" id="gname">Visitante 💖</div></div>
      <div class="av" style="width: 46px; height: 46px; border-radius: 50%; background: linear-gradient(135deg, var(--pk), var(--pk2)); display: flex; align-items: center; justify-content: center; font-weight: 700; color: #fff; cursor: pointer;" onclick="nav('s-profile')">B</div>
    </div>
    <div class="cbar"><div class="ctabs" id="ctabs" style="display: flex; gap: 8px; overflow-x: auto; padding-bottom: 10px;"></div></div>
  </div>
  <div class="sc"><div class="cgrid" id="cgrid"></div></div>
  <div class="nb">
    <div class="ni on" onclick="nav('s-home')"><div class="ic">🏠</div><div class="lb">Início</div></div>
    <div class="ni" onclick="loadMyRequests()"><div class="ic">📋</div><div class="lb">Pedidos</div></div>
    <div class="ni" onclick="nav('s-profile')"><div class="ic">👤</div><div class="lb">Perfil</div></div>
  </div>
</div>

<!-- Pedidos -->
<div class="scr" id="s-requests">
  <div class="tb"><button class="bk" onclick="nav('s-home')">‹</button><div class="tt">Meus Pedidos</div><div class="ph"></div></div>
  <div class="sc" id="requests-list" style="padding: 16px;"></div>
</div>

<!-- Perfil -->
<div class="scr" id="s-profile">
  <div class="tb"><button class="bk" onclick="nav('s-home')">‹</button><div class="tt">Perfil</div><div class="ph"></div></div>
  <div class="sc" style="text-align: center;">
    <div style="background: linear-gradient(160deg, var(--pks), #fff); padding: 36px 20px;">
      <div class="av" style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--pk), var(--pk2)); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36px; font-weight: 700; color: #fff; margin: 0 auto 12px;">💖</div>
      <div style="font-size: 20px; font-weight: 800;" id="pname">Minha Conta</div>
      <div style="color: var(--g5);" id="pemail">—</div>
    </div>
    <div style="margin: 16px;">
      <div class="mrow" style="display: flex; align-items: center; gap: 12px; padding: 15px; background: #fff; border-radius: 14px; margin-bottom: 3px; cursor: pointer;" onclick="load2FAStatus()"><div class="mic" style="width: 36px; height: 36px; background: var(--pks); border-radius: 10px; display: flex; align-items: center; justify-content: center;">🔐</div><div style="flex: 1; text-align: left;">Autenticação 2FA</div><div>›</div></div>
      <button class="btn bgh" style="margin-top: 20px; color: var(--er);" onclick="doLogout()">Sair da conta</button>
    </div>
  </div>
</div>

<!-- 2FA -->
<div class="scr" id="s-2fa">
  <div class="tb"><button class="bk" onclick="nav('s-profile')">‹</button><div class="tt">2FA</div><div class="ph"></div></div>
  <div class="sc" id="content-2fa" style="padding: 20px; text-align: center;"></div>
</div>

</div>

<script>
// ============================================
// ⚠️ COLOQUE A URL DO SEU BACKEND DO RENDER AQUI ⚠️
// Exemplo: const API_URL = 'https://blim-backend.onrender.com';
// ============================================
const API_URL = 'https://blim4-0.onrender.com';

// Splash - 3 segundos
setTimeout(() => {
  const splash = document.getElementById('splash');
  splash.classList.add('hidden');
  setTimeout(() => splash.style.display = 'none', 500);
}, 3000);

// ============================================
let accessToken = localStorage.getItem('accessToken');
let refreshToken = localStorage.getItem('refreshToken');
let currentUser = null;
let currentRequestId = null;
let selectedCategory = null;
let selectedService = null;
let selectedPrice = null;
let selectedPayment = 'pix';
let userLocation = null;
let pending2FA = { required: false };
let resetToken = null;

// Categorias
const CATS = [
  {e:'🔧',n:'Encanamento',s:[{n:'Desentupimento',p:'150'},{n:'Conserto Torneira',p:'80'},{n:'Reparo Vazamento',p:'120'}]},
  {e:'⚡',n:'Elétrica',s:[{n:'Troca Tomada',p:'80'},{n:'Instalação Lustre',p:'120'},{n:'Revisão',p:'200'}]},
  {e:'🏠',n:'Reforma',s:[{n:'Pintura',p:'300'},{n:'Revestimento',p:'400'},{n:'Gesso',p:'350'}]},
  {e:'🧹',n:'Limpeza',s:[{n:'Residencial',p:'100'},{n:'Comercial',p:'200'},{n:'Pós-obra',p:'300'}]}
];

function getDeviceId() {
  let id = localStorage.getItem('deviceId');
  if (!id) { id = 'dev_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6); localStorage.setItem('deviceId', id); }
  return id;
}

async function apiFetch(url, options = {}) {
  const headers = { 'Content-Type': 'application/json', 'X-Device-ID': getDeviceId() };
  if (accessToken) headers['Authorization'] = 'Bearer ' + accessToken;
  
  const res = await fetch(API_URL + url, { ...options, headers });
  
  if (res.status === 401 && refreshToken) {
    const refreshRes = await fetch(API_URL + '/api/auth/refresh', { method: 'POST', body: JSON.stringify({ refreshToken }) });
    if (refreshRes.ok) {
      const data = await refreshRes.json();
      accessToken = data.accessToken;
      localStorage.setItem('accessToken', accessToken);
      headers['Authorization'] = 'Bearer ' + accessToken;
      return fetch(API_URL + url, { ...options, headers });
    }
  }
  
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.error || 'Erro na requisição');
  }
  return res.json();
}

function T(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('on');
  setTimeout(() => t.classList.remove('on'), 3000);
}

let curScr = 's-splash';
function nav(id) {
  document.getElementById(curScr)?.classList.remove('on');
  document.getElementById(id)?.classList.add('on');
  curScr = id;
  if (id === 's-home') { buildTabs(); buildGrid(); loadMyRequests(); }
  if (id === 's-requests') { loadMyRequests(); }
  if (id === 's-profile') { loadUserProfile(); }
}

// ========== CADASTRO ==========
async function doRegister() {
  const name = document.getElementById('rn')?.value || '';
  const email = document.getElementById('re')?.value || '';
  const phone = document.getElementById('rphone')?.value || '';
  const cpf = document.getElementById('rcpf')?.value || '';
  const password = document.getElementById('rpw')?.value || '';
  const terms = document.getElementById('rt')?.checked || false;
  
  if (!name.trim()) { T('Digite seu nome'); return; }
  if (!email.trim()) { T('Digite seu e-mail'); return; }
  if (!password || password.length < 8) { T('Senha deve ter 8+ caracteres'); return; }
  if (!terms) { T('Aceite os termos'); return; }
  
  try {
    T('Cadastrando...');
    await apiFetch('/api/auth/register-cliente', {
      method: 'POST',
      body: JSON.stringify({ name, email, phone, cpf, password })
    });
    T('Conta criada! Faça login.');
    nav('s-login');
  } catch(e) { T(e.message); }
}

// ========== LOGIN ==========
async function doLogin() {
  const email = document.getElementById('le')?.value || '';
  const password = document.getElementById('lp')?.value || '';
  const code2fa = document.getElementById('code2fa')?.value || '';
  
  if (!email.trim()) { T('Digite seu e-mail'); return; }
  if (!password) { T('Digite sua senha'); return; }
  
  if (pending2FA.required && !code2fa) { T('Digite o código 2FA'); return; }
  
  try {
    T('Entrando...');
    const res = await apiFetch('/api/auth/login', {
      method: 'POST',
      body: JSON.stringify({ email, password, deviceId: getDeviceId(), code2fa })
    });
    
    if (res.requiresCode) {
      pending2FA = { required: true };
      document.getElementById('div-2fa').style.display = 'block';
      T('Código 2FA necessário');
      return;
    }
    
    if (res.token) {
      accessToken = res.token;
      refreshToken = res.refreshToken;
      localStorage.setItem('accessToken', accessToken);
      localStorage.setItem('refreshToken', refreshToken);
      currentUser = res.user;
      updateUserUI();
      T('Bem-vinda!');
      nav('s-home');
    }
  } catch(e) { T(e.message); }
}

async function doLogout() {
  try { if (accessToken) await apiFetch('/api/auth/logout', { method: 'POST' }); } catch(e) {}
  accessToken = null;
  localStorage.removeItem('accessToken');
  localStorage.removeItem('refreshToken');
  currentUser = null;
  nav('s-splash');
}

function updateUserUI() {
  if (currentUser) {
    const name = currentUser.name || 'Visitante';
    document.getElementById('gname').innerHTML = name.split(' ')[0] + ' 💖';
    document.getElementById('pname').innerHTML = name;
    document.getElementById('pemail').innerHTML = currentUser.email || '';
  }
}

async function loadUserProfile() {
  if (!accessToken) return;
  try {
    const user = await apiFetch('/api/auth/me');
    currentUser = user;
    updateUserUI();
  } catch(e) {}
}

// ========== RECUPERAR SENHA ==========
async function forgotPassword() {
  const email = document.getElementById('reset-email')?.value || '';
  if (!email.trim()) { T('Digite seu e-mail'); return; }
  try {
    await apiFetch('/api/password/forgot', { method: 'POST', body: JSON.stringify({ email }) });
    T('Link enviado! Verifique seu e-mail.');
    nav('s-login');
  } catch(e) { T(e.message); }
}

function setResetToken(token) {
  resetToken = token;
  nav('s-reset-password');
}

async function submitResetPassword() {
  const newPassword = document.getElementById('new-password')?.value || '';
  const confirmPassword = document.getElementById('confirm-password')?.value || '';
  if (!newPassword || newPassword.length < 8) { T('Senha deve ter 8+ caracteres'); return; }
  if (newPassword !== confirmPassword) { T('As senhas não coincidem'); return; }
  if (!resetToken) { T('Token inválido'); return; }
  try {
    await apiFetch('/api/password/reset', { method: 'POST', body: JSON.stringify({ token: resetToken, password: newPassword }) });
    T('Senha alterada! Faça login.');
    resetToken = null;
    nav('s-login');
  } catch(e) { T(e.message); }
}

// ========== 2FA ==========
async function load2FAStatus() {
  if (!accessToken) { T('Faça login primeiro'); return; }
  try {
    const user = await apiFetch('/api/auth/me');
    if (user.twoFactorEnabled) {
      document.getElementById('content-2fa').innerHTML = '<div><div style="font-size:48px">🔐</div><h2>2FA Ativado</h2><button class="btn ber" onclick="disable2FA()">Desativar</button></div>';
    } else {
      document.getElementById('content-2fa').innerHTML = '<div><div style="font-size:48px">🔓</div><h2>2FA Desativado</h2><button class="btn bpk" onclick="setup2FA()">Ativar</button></div>';
    }
    nav('s-2fa');
  } catch(e) { T(e.message); }
}

async function setup2FA() {
  try {
    const res = await apiFetch('/api/auth/setup-2fa', { method: 'POST' });
    document.getElementById('content-2fa').innerHTML = '<div><h2>Configurar 2FA</h2><img src="' + res.qrCode + '" style="width:200px;margin:20px auto"><div class="iw"><input class="inp" id="2fa-code" placeholder="Código"></div><button class="btn bpk" onclick="enable2FA(\'' + res.secret + '\')">Ativar</button></div>';
  } catch(e) { T(e.message); }
}

async function enable2FA(secret) {
  const code = document.getElementById('2fa-code')?.value || '';
  if (!code) { T('Digite o código'); return; }
  try {
    await apiFetch('/api/auth/enable-2fa', { method: 'POST', body: JSON.stringify({ secret, code }) });
    T('2FA ativado!');
    load2FAStatus();
  } catch(e) { T(e.message); }
}

async function disable2FA() {
  const code = prompt('Digite o código do Google Authenticator:');
  if (!code) return;
  try {
    await apiFetch('/api/auth/disable-2fa', { method: 'POST', body: JSON.stringify({ code }) });
    T('2FA desativado');
    load2FAStatus();
  } catch(e) { T(e.message); }
}

// ========== CATEGORIAS ==========
function buildTabs() {
  const el = document.getElementById('ctabs');
  if (!el) return;
  el.innerHTML = '<div class="ct on" style="padding:8px 16px;border-radius:999px;background:var(--pk);color:#fff;">Todos</div><div style="padding:8px 16px;border-radius:999px;background:#f2f2f7;">Casa</div><div style="padding:8px 16px;border-radius:999px;background:#f2f2f7;">Beleza</div>';
}

function buildGrid() {
  const el = document.getElementById('cgrid');
  if (!el) return;
  el.innerHTML = CATS.map((c, i) => '<div class="cc" onclick="openCategory(' + i + ')"><div style="font-size:30px">' + c.e + '</div><div style="font-size:11px;font-weight:700">' + c.n + '</div></div>').join('');
}

function openCategory(idx) {
  selectedCategory = idx;
  const cat = CATS[idx];
  document.getElementById('svct').innerHTML = cat.e + ' ' + cat.n;
  let html = '';
  for (let j = 0; j < cat.s.length; j++) {
    html += '<div style="display:flex;align-items:center;gap:14px;padding:15px 20px;border-bottom:0.5px solid #eee;cursor:pointer" onclick="selectService(' + idx + ',' + j + ')"><div style="width:52px;height:52px;border-radius:14px;background:var(--pks);display:flex;align-items:center;justify-content:center;font-size:26px">' + cat.e + '</div><div style="flex:1"><div style="font-weight:700">' + cat.s[j].n + '</div><div style="font-size:13px;color:var(--g5)">R$ ' + cat.s[j].p + '</div></div><div style="font-size:20px;color:var(--g7)">›</div></div>';
  }
  document.getElementById('svcl').innerHTML = html;
  nav('s-svcs');
}

function selectService(catIdx, svcIdx) {
  selectedCategory = catIdx;
  selectedService = svcIdx;
  selectedPrice = CATS[catIdx].s[svcIdx].p;
  T('Serviço selecionado: R$ ' + selectedPrice);
  createServiceRequest();
}

// ========== CRIAR SOLICITAÇÃO ==========
async function createServiceRequest() {
  if (selectedCategory === null) { T('Selecione um serviço'); nav('s-home'); return; }
  
  const cat = CATS[selectedCategory];
  const svc = cat.s[selectedService];
  
  try {
    T('Criando solicitação...');
    const res = await apiFetch('/api/requests/create', {
      method: 'POST',
      body: JSON.stringify({
        category: cat.n,
        title: svc.n,
        description: svc.n,
        address: 'Endereço de teste',
        latitude: null,
        longitude: null,
        value: 'R$ ' + svc.p,
        paymentMethod: 'pix'
      })
    });
    currentRequestId = res.requestId;
    T('Solicitação criada! ID: ' + currentRequestId);
    loadMyRequests();
  } catch(e) { T(e.message); }
}

// ========== MEUS PEDIDOS ==========
async function loadMyRequests() {
  if (!accessToken) return;
  try {
    const requests = await apiFetch('/api/requests/my-requests');
    const container = document.getElementById('requests-list');
    if (!container) return;
    if (requests.length === 0) { container.innerHTML = '<div style="text-align:center;padding:40px;color:var(--g5)">Nenhum pedido</div>'; return; }
    let html = '';
    for (let r of requests) {
      html += '<div style="background:#fff;border-radius:14px;padding:16px;margin-bottom:12px;border:1px solid #eee"><div style="display:flex;justify-content:space-between"><span style="font-weight:800">' + (r.category || '') + '</span><span style="background:#E8F8EF;color:#34C759;padding:4px 10px;border-radius:999px;font-size:12px">' + (r.status || '') + '</span></div><div style="margin:8px 0">' + (r.description || '') + '</div><div>💰 ' + (r.value || '') + '</div></div>';
    }
    container.innerHTML = html;
    if (curScr === 's-requests') nav('s-requests');
  } catch(e) { T(e.message); }
}

// ========== INICIALIZAÇÃO ==========
document.addEventListener('DOMContentLoaded', () => {
  buildTabs();
  buildGrid();
  
  if (accessToken) {
    apiFetch('/api/auth/me').then(res => {
      if (res.id) { currentUser = res; updateUserUI(); nav('s-home'); }
    }).catch(() => {});
  }
  
  const urlParams = new URLSearchParams(window.location.search);
  const token = urlParams.get('token');
  if (token) setResetToken(token);
});

